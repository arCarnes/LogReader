<Window x:Class="LogReader.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LogReader.App.ViewModels"
        xmlns:conv="clr-namespace:LogReader.App.Converters"
        Title="LogReader" Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="OnFileDrop" DragOver="OnDragOver">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:EncodingToBoolConverter x:Key="EncToBool"/>
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding SearchPanel.ExecuteSearchCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" CommandParameter="{Binding SelectedTab}"/>
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding ToggleGroupsPanelCommand}"/>
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding ToggleSearchPanelCommand}"/>
        <KeyBinding Key="F10" Command="{Binding ToggleFocusModeCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu + Toolbar -->
        <DockPanel Grid.Row="0" LastChildFill="True">
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="_File">
                    <MenuItem Header="_Open Log File..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                    <Separator/>
                    <MenuItem Header="Import _Group..." Command="{Binding ImportGroupCommand}"/>
                </MenuItem>
                <MenuItem Header="_Controls">
                    <MenuItem Header="Toggle Groups Pane" Command="{Binding ToggleGroupsPanelCommand}" InputGestureText="Ctrl+1"/>
                    <MenuItem Header="Toggle Search Pane" Command="{Binding ToggleSearchPanelCommand}" InputGestureText="Ctrl+2"/>
                    <MenuItem Header="Reader Focus Mode" Command="{Binding ToggleFocusModeCommand}" InputGestureText="F10"/>
                    <Separator/>
                    <MenuItem Header="Keyboard Shortcuts..." Click="ShowControls_Click"/>
                </MenuItem>
            </Menu>
            <ToolBarTray>
                <ToolBar Band="0">
                    <Button Content="Open Log File..." Command="{Binding OpenFileCommand}" Style="{StaticResource ToolBarButton}" ToolTip="Open a log file"/>
                    <Button Content="Import Group" Command="{Binding ImportGroupCommand}" Style="{StaticResource ToolBarButton}" ToolTip="Import Group"/>
                    <Separator/>
                    <Button Content="Controls" Click="ShowControls_Click" Style="{StaticResource ToolBarButton}" ToolTip="Show keyboard shortcuts"/>
                    <Button Content="Settings" Click="OpenSettings" Style="{StaticResource ToolBarButton}"/>
                </ToolBar>
            </ToolBarTray>
        </DockPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" x:Name="GroupsPanelColumn"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="350" x:Name="SearchPanelColumn"/>
            </Grid.ColumnDefinitions>

            <!-- Groups Panel -->
            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
                <Grid>
                    <DockPanel x:Name="GroupsPanelContent">
                        <DockPanel DockPanel.Dock="Top" Background="#F0F0F0" LastChildFill="False">
                            <TextBlock Text="Groups" FontWeight="Bold" Padding="8,6" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="◀"
                                    Command="{Binding ToggleGroupsPanelCommand}"
                                    Style="{StaticResource ToolBarButton}" Padding="8,2" Margin="0,2,4,2"
                                    ToolTip="Collapse groups pane"/>
                        <Button DockPanel.Dock="Right" Content="+" Command="{Binding CreateGroupCommand}"
                                Style="{StaticResource ToolBarButton}" Padding="8,2" Margin="0,2,4,2"
                                ToolTip="Create a new group" FontSize="14" FontWeight="Bold"/>
                        </DockPanel>

                        <!-- Group Tree -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:LogGroupViewModel}">
                                    <Border BorderBrush="#E8E8E8" BorderThickness="0,0,0,1"
                                            Visibility="{Binding IsTreeVisible, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- Group Header Row (indented by depth) -->
                                            <Grid Margin="{Binding IndentMargin}"
                                                  MouseLeftButtonDown="GroupRow_MouseDown"
                                                  Cursor="Hand"
                                                  ToolTip="Click to open group files. Right-click for more actions.">
                                                <Grid.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="Add Child Group"
                                                                  Click="AddChildGroup_Click"
                                                                  Visibility="{Binding CanAddChild, Converter={StaticResource BoolToVis}}"/>
                                                        <MenuItem Header="Manage Files"
                                                                  Click="ManageGroup_Click"
                                                                  Visibility="{Binding CanManageFiles, Converter={StaticResource BoolToVis}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Move Up" Click="MoveGroupUp_Click"/>
                                                        <MenuItem Header="Move Down" Click="MoveGroupDown_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="Export Group" Click="ExportGroup_Click"/>
                                                        <MenuItem Header="Delete Group" Click="DeleteGroup_Click"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Expand toggle -->
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" FontSize="9"
                                                           MouseLeftButtonDown="GroupExpand_MouseDown"
                                                           Cursor="Hand" Foreground="#666">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="▶"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Text" Value="▼"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Spacing -->
                                                <Border Grid.Column="1"/>

                                                <!-- Group name / edit box -->
                                                <TextBlock Grid.Column="2" Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           MouseLeftButtonDown="GroupName_MouseDown">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalAlignment="Center" FontSize="12"
                                                         KeyDown="GroupNameTextBox_KeyDown"
                                                         LostFocus="GroupNameTextBox_LostFocus"
                                                         IsVisibleChanged="GroupNameTextBox_IsVisibleChanged">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                <!-- Action buttons -->
                                                <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                    <!-- Add child (Container groups only) -->
                                                    <Button Content="+" FontSize="10" Padding="3,1" Margin="2,0,0,0"
                                                            Click="AddChildGroup_Click"
                                                            Style="{StaticResource ToolBarButton}" ToolTip="Add child group"
                                                            Visibility="{Binding CanAddChild, Converter={StaticResource BoolToVis}}"/>
                                                    <Button Content="▲" FontSize="9" Padding="3,1" Margin="2,0,0,0"
                                                            Click="MoveGroupUp_Click"
                                                            Visibility="Collapsed"
                                                            Style="{StaticResource ToolBarButton}" ToolTip="Move up"/>
                                                    <Button Content="▼" FontSize="9" Padding="3,1" Margin="2,0,0,0"
                                                            Click="MoveGroupDown_Click"
                                                            Visibility="Collapsed"
                                                            Style="{StaticResource ToolBarButton}" ToolTip="Move down"/>
                                                    <Button Content="📄+" FontSize="11" Padding="4,2" Margin="2,0,0,0"
                                                            Click="ManageGroup_Click"
                                                            Style="{StaticResource ToolBarButton}"
                                                            ToolTip="Add/Remove files"
                                                            Visibility="{Binding CanManageFiles, Converter={StaticResource BoolToVis}}"/>
                                                    <Button Content="Export" FontSize="10" Padding="4,2" Margin="2,0,0,0"
                                                            Click="ExportGroup_Click"
                                                            Visibility="Collapsed"
                                                            Style="{StaticResource ToolBarButton}"/>
                                                    <Button Content="✕" FontSize="10" Padding="4,2" Margin="2,0,0,0"
                                                            Click="DeleteGroup_Click"
                                                            Visibility="Collapsed"
                                                            Style="{StaticResource ToolBarButton}"
                                                            Foreground="Red"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Member files list (expanded) -->
                                            <ItemsControl ItemsSource="{Binding MemberFiles}"
                                                          Margin="28,0,0,4">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:GroupFileMemberViewModel}">
                                                        <StackPanel>
                                                            <StackPanel.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="Open File Location"
                                                                              Click="OpenFileLocation_Click"/>
                                                                </ContextMenu>
                                                            </StackPanel.ContextMenu>
                                                            <TextBlock Text="{Binding FileName}"
                                                                       Padding="4,2" FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding FilePath}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#555"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                                <Setter Property="Foreground" Value="#CC2222"/>
                                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding ErrorMessage}"
                                                                       Padding="4,0,4,2" FontSize="10" Foreground="#CC2222"
                                                                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                    <Button x:Name="GroupsPanelRailButton"
                            Content="▶ Groups"
                            Visibility="Collapsed"
                            Command="{Binding ToggleGroupsPanelCommand}"
                            ToolTip="Open groups pane"
                            Background="#F5F5F5"
                            BorderThickness="0"
                            Padding="6,8"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          DragCompleted="GroupsSplitter_DragCompleted">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGroupsPanelOpen}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Tab Content -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab Headers -->
                <TabControl Grid.Row="0" Grid.RowSpan="2"
                            ItemsSource="{Binding FilteredTabs}"
                            SelectedItem="{Binding SelectedTab}"
                            x:Name="TabControl">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Pin Tab" Click="PinTab_Click" Tag="{Binding}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                            <Setter Property="Header" Value="Unpin Tab"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>
                                        <Separator/>
                                        <MenuItem Header="Close" Click="CloseTab_Click" Tag="{Binding}"/>
                                        <MenuItem Header="Close Others" Click="CloseOtherTabs_Click" Tag="{Binding}"/>
                                        <MenuItem Header="Close All But Pinned" Click="CloseAllButPinned_Click"/>
                                        <MenuItem Header="Close All" Click="CloseAllTabs_Click"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="📌 " VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                <Button Content="x" Margin="6,0,0,0" Padding="2,0"
                                        Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ToolBarButton}" FontSize="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:LogTabViewModel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Tab toolbar: encoding + auto-scroll -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#F5F5F5" Height="28">
                                    <TextBlock Text="Encoding:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                    <RadioButton Content="UTF-8" IsChecked="{Binding Encoding, Converter={StaticResource EncToBool}, ConverterParameter=Utf8}"
                                                 VerticalAlignment="Center" Margin="4,0"/>
                                    <RadioButton Content="ANSI" IsChecked="{Binding Encoding, Converter={StaticResource EncToBool}, ConverterParameter=Ansi}"
                                                 VerticalAlignment="Center" Margin="4,0"/>
                                    <RadioButton Content="UTF-16" IsChecked="{Binding Encoding, Converter={StaticResource EncToBool}, ConverterParameter=Utf16}"
                                                 VerticalAlignment="Center" Margin="4,0"/>
                                    <Separator Margin="8,2"/>
                                    <Button Content="⬆ Top" Command="{Binding JumpToTopCommand}"
                                            Style="{StaticResource ToolBarButton}" Padding="5,2" ToolTip="Jump to top"/>
                                    <Button Content="⬇ Bottom" Command="{Binding JumpToBottomCommand}"
                                            Style="{StaticResource ToolBarButton}" Padding="5,2" ToolTip="Jump to bottom"/>
                                    <Separator Margin="8,2"/>
                                    <CheckBox Content="Auto-scroll" IsChecked="{Binding AutoScrollEnabled}" VerticalAlignment="Center" Margin="4,0"/>
                                </StackPanel>

                                <!-- Log content (virtualized) -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                <ListBox Grid.Column="0"
                                         ItemsSource="{Binding VisibleLines}"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                         ScrollViewer.CanContentScroll="True"
                                         FontFamily="Consolas" FontSize="12"
                                         BorderThickness="0"
                                         x:Name="LogListBox"
                                         PreviewMouseWheel="LogListBox_PreviewMouseWheel"
                                         SizeChanged="LogListBox_SizeChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="RowHighlight" Background="Transparent" Padding="0,0,4,0" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding LineNumber}" Width="45" Foreground="Gray" TextAlignment="Right" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Text}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background"
                                                    Value="{Binding HighlightColor, Converter={StaticResource HexColorToBrush}}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#B0D4FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                            <Style.Resources>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                            </Style.Resources>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                                <ScrollBar Grid.Column="1"
                                           Orientation="Vertical"
                                           Minimum="0"
                                           Maximum="{Binding MaxScrollPosition}"
                                           ViewportSize="{Binding ViewportLineCount}"
                                           Value="{Binding ScrollPosition, Mode=TwoWay}"
                                           SmallChange="3"
                                           LargeChange="50"/>
                                </Grid>

                                <!-- Status bar -->
                                <Border Grid.Row="2" Background="#F0F0F0" BorderThickness="0,1,0,0" BorderBrush="#D0D0D0" Padding="4,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding StatusText}" Margin="0,0,16,0"/>
                                        <TextBlock Text="{Binding FilePath}" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <!-- Empty state -->
                <TextBlock Grid.Row="0" Grid.RowSpan="2"
                           Text="Use Groups to add files and open log sets"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Foreground="Gray">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          DragCompleted="SearchSplitter_DragCompleted">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchPanelOpen}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Search Panel -->
            <Border Grid.Column="4" BorderBrush="#DDD" BorderThickness="1,0,0,0">
                <Grid>
                    <DockPanel x:Name="SearchPanelContent" DataContext="{Binding SearchPanel}">
                        <StackPanel DockPanel.Dock="Top" Margin="8">
                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                <TextBlock Text="Search" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right"
                                        Content="▶"
                                        Command="{Binding DataContext.ToggleSearchPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Style="{StaticResource ToolBarButton}"
                                        Padding="8,2"
                                        ToolTip="Collapse search pane"/>
                            </DockPanel>
                        <TextBox Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SearchTextBox}"
                                 x:Name="SearchBox">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ExecuteSearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <WrapPanel Margin="0,6,0,0">
                            <CheckBox Content="Regex" IsChecked="{Binding IsRegex}" Margin="0,0,12,4"/>
                            <CheckBox Content="Case sensitive" IsChecked="{Binding CaseSensitive}" Margin="0,0,12,4"/>
                            <CheckBox Content="Whole word" IsChecked="{Binding WholeWord}" Margin="0,0,12,4"/>
                        </WrapPanel>
                        <DockPanel Margin="0,6,0,0">
                            <TextBlock Text="Search in:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="Gray"/>
                            <ComboBox Width="160"
                                      ItemsSource="{Binding ScopeItems}"
                                      SelectedItem="{Binding SelectedScope}"
                                      DisplayMemberPath="Label">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectable}" Value="False">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter Property="Foreground" Value="#AAA"/>
                                                <Setter Property="FontSize" Value="10"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Search" Command="{Binding ExecuteSearchCommand}" Padding="12,4" Margin="0,0,4,0"/>
                            <Button Content="Cancel" Command="{Binding CancelSearchCommand}" Padding="12,4" Margin="0,0,4,0"
                                    Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="Clear" Command="{Binding ClearResultsCommand}" Padding="12,4"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,6,0,0"
                                     Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding StatusText}" Margin="0,4,0,0" Foreground="Gray"/>
                    </StackPanel>

                    <!-- Search Results -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Results}"
                                      HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:FileSearchResultViewModel}">
                                    <Expander IsExpanded="{Binding IsExpanded}" Margin="0,0,0,4">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding HitCount, StringFormat=' ({0})'}" Foreground="Gray"/>
                                            </StackPanel>
                                        </Expander.Header>
                                        <ListBox ItemsSource="{Binding Hits}"
                                                 MaxHeight="400"
                                                 HorizontalContentAlignment="Stretch"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 Background="Transparent" BorderThickness="0">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <ContentPresenter/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.NavigateToHitCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}"
                                                            Cursor="Hand" HorizontalContentAlignment="Stretch"
                                                            Background="Transparent" BorderThickness="0" Padding="2,1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="60"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding LineNumber, StringFormat='L{0}: '}"
                                                                       Foreground="DarkBlue"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding LineText}" Style="{StaticResource LogText}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    </DockPanel>
                    <Button x:Name="SearchPanelRailButton"
                            Visibility="Collapsed"
                            Content="Search ◀"
                            Command="{Binding ToggleSearchPanelCommand}"
                            ToolTip="Open search pane"
                            Background="#F5F5F5"
                            BorderThickness="0"
                            Padding="6,8"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding TabCountText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
