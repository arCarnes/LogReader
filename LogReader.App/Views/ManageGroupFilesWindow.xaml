<Window x:Class="LogReader.App.Views.ManageGroupFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding GroupName, StringFormat='Manage Dashboard Files - {0}'}"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Check files to include in this dashboard:" Foreground="Gray" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Add Files..." Padding="6,2" Margin="0,0,4,0" Click="AddFiles_Click"/>
                <Button Content="Select All" Padding="6,2" Margin="0,0,4,0" Click="SelectAll_Click"/>
                <Button Content="Deselect All" Padding="6,2" Click="DeselectAll_Click"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Files}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}" Padding="4,6" Margin="4,0"
                                      VerticalContentAlignment="Center">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding FilePath}" Foreground="Gray" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4,6" Margin="0,0,8,0" IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" Padding="4,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
