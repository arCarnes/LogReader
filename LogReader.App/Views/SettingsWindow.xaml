<Window x:Class="LogReader.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LogReader.App.ViewModels"
        xmlns:conv="clr-namespace:LogReader.App.Converters"
        Title="Settings" Width="760" Height="600"
        MinWidth="700" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
        <Style x:Key="SwatchButton" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#999"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- General -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="General" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Default open directory"/>
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding DefaultOpenDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,2"
                         IsReadOnly="True"
                         Background="{StaticResource AppSurfaceBrush}"/>
                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseDefaultDirectoryCommand}"
                        Padding="8,4" Margin="8,0,0,0"/>
                <Button Grid.Column="2" Content="Clear" Command="{Binding ClearDefaultDirectoryCommand}"
                        Padding="8,4" Margin="4,0,0,0"/>
            </Grid>

            <CheckBox Grid.Row="2" Grid.ColumnSpan="2"
                      Content="Enable auto-tail for visible tabs"
                      IsChecked="{Binding GlobalAutoTailEnabled}"
                      Margin="0,10,0,0"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Default file encoding"/>
            <ComboBox Grid.Row="3" Grid.Column="1"
                      Width="280"
                      HorizontalAlignment="Left"
                      Margin="0,10,0,0"
                      ItemsSource="{x:Static vm:SettingsViewModel.DefaultEncodingOptions}"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding DefaultFileEncoding, Mode=TwoWay}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Fallback encodings (order)"/>
            <Grid Grid.Row="4" Grid.Column="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          Margin="0,0,8,0"
                          ItemsSource="{x:Static vm:SettingsViewModel.FallbackEncodingOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding FallbackEncoding1, Mode=TwoWay}"/>
                <ComboBox Grid.Column="1"
                          Margin="0,0,8,0"
                          ItemsSource="{x:Static vm:SettingsViewModel.FallbackEncodingOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding FallbackEncoding2, Mode=TwoWay}"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{x:Static vm:SettingsViewModel.FallbackEncodingOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding FallbackEncoding3, Mode=TwoWay}"/>
            </Grid>

            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Log font"/>
            <ComboBox Grid.Row="5" Grid.Column="1"
                      Width="280"
                      HorizontalAlignment="Left"
                      Margin="0,10,0,0"
                      ItemsSource="{x:Static vm:SettingsViewModel.LogFontOptions}"
                      SelectedItem="{Binding LogFontFamily, Mode=TwoWay}"/>
        </Grid>

        <!-- Line Highlighting -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Line Highlighting" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="+ Add Rule"
                        Command="{Binding AddRuleCommand}"
                        Padding="8,3" HorizontalAlignment="Right"/>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="32"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Pattern" Foreground="Gray" FontSize="11" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="2" Text="Regex" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Case" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Color" Foreground="Gray" FontSize="11" Margin="4,0,0,0"/>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding HighlightRules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:HighlightRuleViewModel}">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <TextBox Grid.Column="1" Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="4,2" Margin="4,0"/>

                                <CheckBox Grid.Column="2" IsChecked="{Binding IsRegex}"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <CheckBox Grid.Column="3" IsChecked="{Binding CaseSensitive}"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                    <Button Style="{StaticResource SwatchButton}" Background="#FFCCCC"
                                            Tag="#FFCCCC" Click="PresetColor_Click" ToolTip="Red"/>
                                    <Button Style="{StaticResource SwatchButton}" Background="#FFE0B2"
                                            Tag="#FFE0B2" Click="PresetColor_Click" ToolTip="Orange"/>
                                    <Button Style="{StaticResource SwatchButton}" Background="#FFFF99"
                                            Tag="#FFFF99" Click="PresetColor_Click" ToolTip="Yellow"/>
                                    <Button Style="{StaticResource SwatchButton}" Background="#CCFFCC"
                                            Tag="#CCFFCC" Click="PresetColor_Click" ToolTip="Green"/>
                                    <Button Content="..." Padding="4,1" Margin="4,0,0,0" FontSize="11"
                                            Tag="{Binding}" Click="PickColor_Click" ToolTip="Custom color..."/>
                                    <Border Width="22" Height="14" Margin="4,0,0,0" BorderThickness="1" BorderBrush="#999"
                                            Background="{Binding Color, Converter={StaticResource HexColorToBrush}}"
                                            VerticalAlignment="Center"/>
                                </StackPanel>

                                <Button Grid.Column="5" Content="X" Padding="3,1" FontSize="11"
                                        Foreground="Red" VerticalAlignment="Center"
                                        Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4,6" Margin="0,0,8,0" IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" Padding="4,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
