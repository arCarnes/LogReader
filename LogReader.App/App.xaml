<Application x:Class="LogReader.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose"
             >
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EDECEA"/>
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#E8E7E5"/>
            <SolidColorBrush x:Key="AppLogContentBrush" Color="#E7E6E4"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#C6C3BE"/>
            <SolidColorBrush x:Key="AppTextBrush" Color="#2C2926"/>
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#76716B"/>
            <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#EFEEEC"/>
            <SolidColorBrush x:Key="AppSelectedTabBrush" Color="#EFEEEC"/>
            <SolidColorBrush x:Key="AppHoverBrush" Color="#E6E4E1"/>
            <SolidColorBrush x:Key="AppSelectionBrush" Color="#C4D1D8"/>
            <SolidColorBrush x:Key="AppSearchHighlightBrush" Color="#B4C8D2"/>
            <SolidColorBrush x:Key="AppFocusBorderBrush" Color="#8498A2"/>
            <SolidColorBrush x:Key="AppSelectedTabBorderBrush" Color="#AFAAA4"/>
            <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#8D8882"/>
            <SolidColorBrush x:Key="AppErrorBrush" Color="#C82020"/>
            <FontFamily x:Key="LogFontFamilyResource">Consolas</FontFamily>

            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
            <Style x:Key="ToolBarButton" TargetType="Button">
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
            <Style x:Key="SearchTextBox" TargetType="TextBox">
                <Setter Property="Padding" Value="4,2"/>
                <Setter Property="FontFamily" Value="{DynamicResource LogFontFamilyResource}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource AppInputBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            </Style>
            <Style x:Key="LogText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource LogFontFamilyResource}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
