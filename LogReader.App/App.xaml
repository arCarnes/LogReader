<Application x:Class="LogReader.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose"
             >
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F2F0"/>
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#EEEDEB"/>
            <SolidColorBrush x:Key="AppLogContentBrush" Color="#EDECEA"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#CCC9C4"/>
            <SolidColorBrush x:Key="AppTextBrush" Color="#2C2926"/>
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#7A756F"/>
            <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#F5F4F2"/>
            <SolidColorBrush x:Key="AppSelectedTabBrush" Color="#F5F4F2"/>
            <SolidColorBrush x:Key="AppHoverBrush" Color="#ECEAE7"/>
            <SolidColorBrush x:Key="AppSelectionBrush" Color="#C8D5DC"/>
            <SolidColorBrush x:Key="AppSearchHighlightBrush" Color="#B8CCD6"/>
            <SolidColorBrush x:Key="AppFocusBorderBrush" Color="#8A9EA8"/>
            <SolidColorBrush x:Key="AppSelectedTabBorderBrush" Color="#B5B0AA"/>
            <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#918C86"/>
            <SolidColorBrush x:Key="AppErrorBrush" Color="#CC2222"/>
            <FontFamily x:Key="LogFontFamilyResource">Consolas</FontFamily>

            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
            <Style x:Key="ToolBarButton" TargetType="Button">
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
            <Style x:Key="SearchTextBox" TargetType="TextBox">
                <Setter Property="Padding" Value="4,2"/>
                <Setter Property="FontFamily" Value="{DynamicResource LogFontFamilyResource}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="{StaticResource AppInputBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            </Style>
            <Style x:Key="LogText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource LogFontFamilyResource}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
