<Application x:Class="LogReader.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LogReader.App.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             ShutdownMode="OnMainWindowClose"
             >
    <Application.Resources>
        <ResourceDictionary>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
            <conv:InverseBooleanConverter x:Key="InvertBool"/>
            <conv:LessThanConverter x:Key="LessThan"/>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F4F6"/>
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#ECEFF1"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#D2D7DE"/>
            <SolidColorBrush x:Key="AppTextBrush" Color="#1F2937"/>
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#5B6470"/>
            <FontFamily x:Key="LogFontFamilyResource">Consolas</FontFamily>
            <sys:Double x:Key="LogViewportFontSizeResource">12</sys:Double>

            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Icon" Value="pack://application:,,,/Assets/favicon.ico"/>
            </Style>
            <Style x:Key="ToolBarButton" TargetType="Button">
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
            <Style x:Key="SearchTextBox" TargetType="TextBox">
                <Setter Property="Padding" Value="4,2"/>
                <Setter Property="FontFamily" Value="{DynamicResource LogFontFamilyResource}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="Background" Value="#FAFBFC"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            </Style>
            <Style x:Key="LogText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{DynamicResource LogFontFamilyResource}"/>
                <Setter Property="FontSize" Value="{DynamicResource LogViewportFontSizeResource}"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
