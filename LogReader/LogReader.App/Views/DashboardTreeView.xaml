<UserControl x:Class="LogReader.App.Views.DashboardTreeView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LogReader.App.Controls"
             xmlns:vm="clr-namespace:LogReader.App.ViewModels"
             xmlns:model="clr-namespace:LogReader.Core.Models;assembly=LogReader.Core"
             Background="Transparent">
    <Border BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,1,0">
        <Grid>
            <DockPanel x:Name="GroupsPanelContent" Margin="0,0,14,0">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGroupsPanelOpen}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <StackPanel DockPanel.Dock="Top" Background="{StaticResource AppSurfaceBrush}">
                    <Grid Margin="8,6,8,2">
                        <TextBlock Text="Dashboards" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="8,0,8,4">
                        <Button Command="{Binding CreateContainerGroupCommand}" Style="{StaticResource ToolBarButton}" Padding="6,2" ToolTip="Create a new top-level folder">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" Margin="0,0,4,0"/>
                                <TextBlock Text="+ Folder"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CreateGroupCommand}" Style="{StaticResource ToolBarButton}" Padding="6,2" ToolTip="Create a new top-level dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xF246;" Margin="0,0,4,0"/>
                                <TextBlock Text="+ Dashboard"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Grid Margin="8,0,8,6" Width="160">
                        <Border CornerRadius="6" Background="#FAFBFC" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=DashboardFilterBox}" Value="True">
                                            <Setter Property="BorderBrush" Value="#8FA9C4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBox x:Name="DashboardFilterBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10,3,8,3"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding DashboardTreeFilter, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filter dashboards/folders"/>
                        <TextBlock Text="Search..." Margin="11,0,0,0" VerticalAlignment="Center" Foreground="#9099A5" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=DashboardFilterBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <StackPanel Margin="8,0,8,6" Visibility="{Binding IsDashboardLoading, Converter={StaticResource BoolToVis}}">
                        <ProgressBar IsIndeterminate="True" Height="3"/>
                        <TextBlock Text="{Binding DashboardLoadingStatusText}" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource AppMutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <Button DockPanel.Dock="Top"
                        Command="{Binding ShowAdHocTabsCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Focusable="False"
                        HorizontalContentAlignment="Stretch"
                        Padding="0"
                        ToolTip="Show open tabs that are not assigned to any dashboard">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Date Shift" SubmenuOpened="AdHocModifiers_SubmenuOpened">
                                <MenuItem Header="Loading..." IsEnabled="False"/>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </ControlTemplate>
                    </Button.Template>
                    <Border BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdHocScopeActive}" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid MinHeight="26" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="1"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AdHocScopeChipText}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                </Button>

                <ListBox x:Name="GroupItemsControl"
                         ItemsSource="{Binding Groups}"
                         Background="Transparent"
                         BorderThickness="0"
                         AllowDrop="True"
                         DragOver="GroupTree_DragOver"
                         DragLeave="GroupTree_DragLeave"
                         Drop="GroupTree_Drop"
                         ScrollViewer.CanContentScroll="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Expand All Folders" Command="{Binding ExpandAllFoldersCommand}"/>
                            <MenuItem Header="Collapse All Folders" Command="{Binding CollapseAllFoldersCommand}"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LogGroupViewModel}">
                            <Border BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Visibility="{Binding IsTreeVisible, Converter={StaticResource BoolToVis}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static model:LogGroupKind.Branch}">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Margin="{Binding IndentMargin}" MouseLeftButtonDown="GroupRow_MouseDown" PreviewMouseMove="GroupRow_PreviewMouseMove" Cursor="Hand" ToolTip="Click to open dashboard files. Row buttons create items here.">
                                        <Grid.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="New Folder Here" Click="AddChildFolder_Click" Visibility="{Binding CanAddChild, Converter={StaticResource BoolToVis}}"/>
                                                <MenuItem Header="New Dashboard Here" Click="AddChildDashboard_Click" Visibility="{Binding CanAddChild, Converter={StaticResource BoolToVis}}"/>
                                                <MenuItem Header="Add Files..." Click="AddFiles_Click" Visibility="{Binding CanManageFiles, Converter={StaticResource BoolToVis}}"/>
                                                <MenuItem Header="Bulk Open Files..." Click="BulkOpenFiles_Click" Visibility="{Binding CanManageFiles, Converter={StaticResource BoolToVis}}"/>
                                                <MenuItem Header="Date Shift" SubmenuOpened="DashboardModifiers_SubmenuOpened" Visibility="{Binding CanManageFiles, Converter={StaticResource BoolToVis}}">
                                                    <MenuItem Header="Loading..." IsEnabled="False"/>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Move Up" Click="MoveGroupUp_Click"/>
                                                <MenuItem Header="Move Down" Click="MoveGroupDown_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Delete Item" Click="DeleteGroup_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Expand All Folders" Command="{Binding DataContext.ExpandAllFoldersCommand, Source={x:Reference Root}}"/>
                                                <MenuItem Header="Collapse All Folders" Command="{Binding DataContext.CollapseAllFoldersCommand, Source={x:Reference Root}}"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="9" MouseLeftButtonDown="GroupExpand_MouseDown" Cursor="Hand" Foreground="#666" Visibility="{Binding CanExpand, Converter={StaticResource BoolToVis}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#x25B6;"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="Text" Value="&#x25BC;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Grid.Column="1"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" MouseLeftButtonDown="GroupName_MouseDown">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static model:LogGroupKind.Branch}">
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Grid.Column="2" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" FontSize="12" KeyDown="GroupNameTextBox_KeyDown" LostFocus="GroupNameTextBox_LostFocus" IsVisibleChanged="GroupNameTextBox_IsVisibleChanged">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                                            <Button Content="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Padding="3,1" Margin="2,0,0,0" Click="AddChildFolder_Click" Style="{StaticResource ToolBarButton}" ToolTip="Create a new folder here" Visibility="{Binding CanAddChild, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="&#xF246;" FontFamily="Segoe MDL2 Assets" FontSize="12" Padding="3,1" Margin="2,0,0,0" Click="AddChildDashboard_Click" Style="{StaticResource ToolBarButton}" ToolTip="Create a new dashboard here" Visibility="{Binding CanAddChild, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="&#x25B2;" FontSize="9" Padding="3,1" Margin="2,0,0,0" Click="MoveGroupUp_Click" Visibility="Collapsed" Style="{StaticResource ToolBarButton}" ToolTip="Move up"/>
                                            <Button Content="&#x25BC;" FontSize="9" Padding="3,1" Margin="2,0,0,0" Click="MoveGroupDown_Click" Visibility="Collapsed" Style="{StaticResource ToolBarButton}" ToolTip="Move down"/>
                                            <Button Content="&#x1F4C4;+" FontSize="11" Padding="4,2" Margin="2,0,0,0" Click="AddFiles_Click" Style="{StaticResource ToolBarButton}" ToolTip="Add files" Visibility="{Binding CanManageFiles, Converter={StaticResource BoolToVis}}"/>
                                            <Button FontSize="11" Padding="4,2" Margin="2,0,0,0" Click="BulkOpenFiles_Click" Style="{StaticResource ToolBarButton}" ToolTip="Bulk Open Files" Visibility="{Binding CanManageFiles, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x1F4C4;" Margin="0,0,-3,0"/>
                                                    <TextBlock Text="&#x1F4C4;"/>
                                                    <TextBlock Text="+" Margin="1,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Content="&#x2715;" FontSize="10" Padding="4,2" Margin="2,0,0,0" Click="DeleteGroup_Click" Style="{StaticResource ToolBarButton}" Foreground="Red"/>
                                        </StackPanel>
                                    </Grid>
                                    <ListBox ItemsSource="{Binding MemberFiles}"
                                             Margin="28,0,0,4"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="240"
                                             ScrollViewer.CanContentScroll="True"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Pixel">
                                        <ListBox.Style>
                                            <Style TargetType="ListBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Style>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Focusable" Value="False"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <ContentPresenter/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:GroupFileMemberViewModel}">
                                                <Border Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="#BCD7F4"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Copy Full Path" Click="CopyFullPath_Click"/>
                                                            <MenuItem Header="Open File Location" Click="OpenFileLocation_Click"/>
                                                            <MenuItem Header="Remove from Dashboard" Click="RemoveDashboardFile_Click"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <StackPanel Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                        <controls:DashboardPathTextBlock FileName="{Binding FileName}" FilePath="{Binding FilePath}" ShowFullPath="{Binding ShowFullPath}" Padding="4,2" FontSize="11" TextTrimming="CharacterEllipsis" Cursor="Hand" Tag="{Binding Tag, RelativeSource={RelativeSource AncestorType=StackPanel}}" MouseLeftButtonDown="OpenMemberFile_Click" ToolTip="{Binding FilePath}">
                                                            <controls:DashboardPathTextBlock.Style>
                                                                <Style TargetType="{x:Type controls:DashboardPathTextBlock}">
                                                                    <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Foreground" Value="#143A5A"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                                                            <Setter Property="Foreground" Value="#CC2222"/>
                                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </controls:DashboardPathTextBlock.Style>
                                                        </controls:DashboardPathTextBlock>
                                                        <TextBlock Text="{Binding ErrorMessage}" Padding="4,0,4,2" FontSize="10" Foreground="#CC2222" Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
            <Button x:Name="GroupsPanelRailButton" Command="{Binding ToggleGroupsPanelCommand}" ToolTip="Open dashboards pane" Background="{StaticResource AppSurfaceBrush}" BorderThickness="0" Padding="4,8">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGroupsPanelOpen}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#x25B6;" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xECA5;" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Width="14" HorizontalAlignment="Right" VerticalAlignment="Stretch" Command="{Binding ToggleGroupsPanelCommand}" ToolTip="Collapse dashboards pane" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1,0,0,0" Padding="0" Content="&#x25C0;">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGroupsPanelOpen}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</UserControl>
