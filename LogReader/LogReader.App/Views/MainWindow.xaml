<Window x:Class="LogReader.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:view="clr-namespace:LogReader.App.Views"
        Title="LogReader"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Drop="OnFileDrop"
        DragOver="OnDragOver">
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" CommandParameter="{Binding SelectedTab}"/>
        <KeyBinding Key="Left" Modifiers="Ctrl" Command="{Binding SelectPreviousTabCommand}"/>
        <KeyBinding Key="Right" Modifiers="Ctrl" Command="{Binding SelectNextTabCommand}"/>
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding ToggleGroupsPanelCommand}"/>
        <KeyBinding Key="F10" Command="{Binding ToggleFocusModeCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <ToolBarTray>
                <ToolBar Band="0">
                    <Button Content="Open Log Files" Command="{Binding OpenFileCommand}" Style="{StaticResource ToolBarButton}" ToolTip="Open a log file"/>
                    <Button Content="Bulk Open Files" Command="{Binding BulkOpenAdHocFilesCommand}" Style="{StaticResource ToolBarButton}" ToolTip="Paste many file paths to open them in Ad Hoc"/>
                    <Separator/>
                    <Button Content="Export View" Command="{Binding ExportViewCommand}" Style="{StaticResource ToolBarButton}" ToolTip="Export the current dashboard view"/>
                    <Button Content="Import View" Command="{Binding ImportViewCommand}" Style="{StaticResource ToolBarButton}" ToolTip="Import a saved dashboard view"/>
                    <Separator/>
                    <Button Content="Hotkeys" Click="ShowControls_Click" Style="{StaticResource ToolBarButton}" ToolTip="Show keyboard shortcuts"/>
                    <Button Content="Settings" Click="OpenSettings" Style="{StaticResource ToolBarButton}"/>
                </ToolBar>
            </ToolBarTray>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" x:Name="GroupsPanelColumn"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <view:DashboardTreeView Grid.Column="0"/>

                <GridSplitter Grid.Column="1"
                          Width="10"
                          Margin="-5,0,-5,0"
                          Background="Transparent"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Panel.ZIndex="1"
                          DragCompleted="GroupsSplitter_DragCompleted"
                          ToolTip="Drag to resize dashboards pane.">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <Border Width="1"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource AppBorderBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </GridSplitter.Template>
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGroupsPanelOpen}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="260" MinHeight="140" x:Name="SearchPanelRow"/>
                </Grid.RowDefinitions>
                <view:TabStripView Grid.Row="0"/>
                <view:LogViewportView Grid.Row="1"/>
                <GridSplitter Grid.Row="2"
                              Height="10"
                              Margin="0,-5,0,-5"
                              Background="Transparent"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True"
                              Panel.ZIndex="1"
                              DragCompleted="SearchSplitter_DragCompleted"
                              ToolTip="Drag to resize search workspace.">
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="{TemplateBinding Background}">
                                <Border Height="1"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource AppBorderBrush}"/>
                            </Grid>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>
                <view:SearchWorkspaceView x:Name="SearchWorkspace" Grid.Row="3"/>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentScopeSummaryText}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding TabCountText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
