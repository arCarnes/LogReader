<Window x:Class="LogReader.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LogReader.App.ViewModels"
        xmlns:conv="clr-namespace:LogReader.App.Converters"
        Title="Settings" Width="860" Height="760"
        MinWidth="780" MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="RecentColorButton" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- General -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
             <Grid.RowDefinitions>
                 <RowDefinition Height="Auto"/>
                 <RowDefinition Height="Auto"/>
                 <RowDefinition Height="Auto"/>
                 <RowDefinition Height="Auto"/>
                 <RowDefinition Height="Auto"/>
                 <RowDefinition Height="Auto"/>
             </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="General" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Default open directory"/>
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding DefaultOpenDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,2"
                         IsReadOnly="True"
                         Background="{StaticResource AppSurfaceBrush}"/>
                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseDefaultDirectoryCommand}"
                        Padding="8,4" Margin="8,0,0,0"/>
                <Button Grid.Column="2" Content="Clear" Command="{Binding ClearDefaultDirectoryCommand}"
                        Padding="8,4" Margin="4,0,0,0"/>
            </Grid>

             <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Log font"/>
             <Grid Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                 <ComboBox Grid.Column="0"
                           Margin="0,0,8,0"
                           ItemsSource="{x:Static vm:SettingsViewModel.LogFontOptions}"
                           SelectedItem="{Binding LogFontFamily, Mode=TwoWay}"/>
                 <ComboBox Grid.Column="1"
                           Width="96"
                           ItemsSource="{x:Static vm:SettingsViewModel.LogFontSizeOptions}"
                           SelectedItem="{Binding LogFontSize, Mode=TwoWay}"/>
             </Grid>

             <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Dashboard file labels"/>
             <CheckBox Grid.Row="3"
                       Grid.Column="1"
                       Margin="0,10,0,0"
                       Content="Show full paths in dashboards when space allows"
                       IsChecked="{Binding ShowFullPathsInDashboard, Mode=TwoWay}"/>

         </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Line Highlighting -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Line Highlighting" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Clear Recent Colors"
                                Command="{Binding ClearRecentHighlightColorsCommand}"
                                Padding="8,3" Margin="0,0,6,0"/>
                        <Button Content="+ Add Rule"
                                Command="{Binding AddRuleCommand}"
                                Padding="8,3"/>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="316"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Pattern" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="Regex" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Case" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Color" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding HighlightRules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:HighlightRuleViewModel}">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="316"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <TextBox Grid.Column="1" Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="4,2" Margin="4,0"/>

                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsRegex}"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <CheckBox Grid.Column="3" IsChecked="{Binding CaseSensitive}"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                        <Border Width="24" Height="18"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                Background="{Binding Color, Converter={StaticResource HexColorToBrush}}"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding Color}"/>
                                        <Button Content="Choose..." Padding="7,2" Margin="8,0,0,0" FontSize="11"
                                                Tag="{Binding}" Click="PickColor_Click" ToolTip="Choose custom color"/>
                                        <TextBlock Text="Recent" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11"
                                                   Margin="10,0,5,0" VerticalAlignment="Center"/>
                                        <ItemsControl ItemsSource="{Binding DataContext.RecentHighlightColors, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Tag="{Binding}"
                                                      VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" MaxWidth="176"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource RecentColorButton}"
                                                            Background="{Binding Converter={StaticResource HexColorToBrush}}"
                                                            Tag="{Binding}"
                                                            Click="RecentColor_Click"
                                                            ToolTip="{Binding}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Button Grid.Column="5" Content="X" Padding="3,1" FontSize="11"
                                            Foreground="{StaticResource AppErrorBrush}" VerticalAlignment="Center"
                                            Command="{Binding DataContext.RemoveRuleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Date Rolling Replacement Patterns -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Date Rolling Replacement Patterns" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="+ Add Pattern"
                            Command="{Binding AddDateRollingPatternCommand}"
                            Padding="8,3" HorizontalAlignment="Right"/>
                </DockPanel>

                <TextBlock Grid.Row="1" FontSize="11" Foreground="{StaticResource AppMutedTextBrush}" Margin="0,0,0,6" TextWrapping="Wrap">
                    Replace must include a date placeholder such as {yyyyMMdd} or {yyyy-MM-dd_HHmmss}. Patterns are tried from top to bottom.
                </TextBlock>

                <Grid Grid.Row="2" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="1" Text="Find" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="Replace" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="Order" Foreground="{StaticResource AppMutedTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                </Grid>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding DateRollingPatterns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ReplacementPatternViewModel}">
                                <StackPanel Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4,2" Margin="0,0,4,0">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNameInvalid}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AppErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <TextBox Grid.Column="1"
                                                 Text="{Binding FindPattern, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4,2" Margin="0,0,4,0"
                                                 FontFamily="Consolas"/>

                                        <TextBox Grid.Column="2"
                                                 Text="{Binding ReplacePattern, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4,2" Margin="0,0,4,0"
                                                 FontFamily="Consolas">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsReplacePatternInvalid}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AppErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="&#x25B2;" Width="30" Padding="2,1" FontSize="10" Margin="0,0,4,0" ToolTip="Move pattern up"
                                                    Command="{Binding DataContext.MoveDateRollingPatternUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="&#x25BC;" Width="30" Padding="2,1" FontSize="10" ToolTip="Move pattern down"
                                                    Command="{Binding DataContext.MoveDateRollingPatternDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                        <Button Grid.Column="4" Content="X" Padding="3,1" FontSize="11"
                                                Foreground="{StaticResource AppErrorBrush}" VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveDateRollingPatternCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ValidationError}"
                                                   Foreground="{StaticResource AppErrorBrush}" FontSize="10"
                                                   Margin="4,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Grid>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Padding="4,6" Margin="0,0,8,0" IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" Padding="4,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
