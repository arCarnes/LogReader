<UserControl x:Class="LogReader.App.Views.SearchWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LogReader.App.ViewModels"
             Background="Transparent">
    <UserControl.Resources>
        <SolidColorBrush x:Key="SearchWorkspaceControlsSurfaceBrush" Color="#EEF3F7"/>
        <SolidColorBrush x:Key="SearchWorkspaceControlsBorderBrush" Color="#C3CDD8"/>
        <SolidColorBrush x:Key="SearchWorkspaceResultsDividerBrush" Color="#B7C2CE"/>
        <SolidColorBrush x:Key="SearchWorkspaceFileHeaderBrush" Color="#F6F8FA"/>
        <Style x:Key="DisclosureHeaderTriangleStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="&#x25B6;"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                    <Setter Property="Text" Value="&#x25BC;"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DisclosureExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Padding="0"
                                          HorizontalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="9"
                                               Foreground="#666"
                                               Style="{StaticResource DisclosureHeaderTriangleStyle}"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </ToggleButton>
                            <Grid x:Name="ExpandedContent" Margin="0,0,0,1" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1"
                                        Margin="0,1,0,1"
                                        Background="{StaticResource AppBorderBrush}"
                                        Opacity="0.7"
                                        SnapsToDevicePixels="True"/>
                                <ContentPresenter Grid.Column="3"/>
                            </Grid>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandedContent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0">
        <Grid Margin="6,4,6,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SearchWorkspaceControlsSurfaceBrush}"
                    BorderBrush="{StaticResource SearchWorkspaceControlsBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8,6,8,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0" Margin="0,0,0,4" VerticalAlignment="Center" ItemHeight="22" DataContext="{Binding SearchPanel}">
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Target:" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold"/>
                    <RadioButton Content="Current tab" IsChecked="{Binding IsCurrentTabTarget}" GroupName="SearchTarget" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Current scope" IsChecked="{Binding IsCurrentScopeTarget}" GroupName="SearchTarget" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Width="1" Height="14" Margin="0,0,8,0" Background="{StaticResource AppBorderBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Source:" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold"/>
                    <RadioButton Content="Disk" IsChecked="{Binding IsDiskSnapshotMode}" GroupName="SearchDataMode" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Tail" IsChecked="{Binding IsTailMode}" GroupName="SearchDataMode" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Snapshot + Tail" IsChecked="{Binding IsSnapshotAndTailMode}" GroupName="SearchDataMode" VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>

            <StackPanel Grid.Row="1" DataContext="{Binding SearchPanel}" Margin="0,0,0,0">
                <Grid x:Name="SearchPrimaryRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,0,5,0">
                        <Border CornerRadius="6" Background="#FAFBFC" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchBox}" Value="True">
                                            <Setter Property="BorderBrush" Value="#8FA9C4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Padding="9,2,7,2" VerticalContentAlignment="Center" Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ExecuteSearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock Text="Search files..." Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#9099A5" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,6,0" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActualWidth, ElementName=SearchPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <CheckBox Content="Regex" IsChecked="{Binding IsRegex}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <CheckBox Content="Case" IsChecked="{Binding CaseSensitive}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Search" Command="{Binding ExecuteSearchCommand}" Padding="10,2" Margin="0,0,3,0" MinWidth="74">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActualWidth, ElementName=SearchPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="3" Content="Cancel" Command="{Binding CancelSearchCommand}" Padding="10,2" Margin="0,0,3,0" MinWidth="74">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActualWidth, ElementName=SearchPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="4" Content="Clear" Command="{Binding ClearResultsCommand}" Padding="10,2" MinWidth="66">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActualWidth, ElementName=SearchPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
                <WrapPanel Margin="0,3,0,0" VerticalAlignment="Center" ItemHeight="22">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActualWidth, ElementName=SearchPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <CheckBox Content="Regex" IsChecked="{Binding IsRegex}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <CheckBox Content="Case" IsChecked="{Binding CaseSensitive}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Search" Command="{Binding ExecuteSearchCommand}" Padding="10,2" Margin="0,0,3,0" MinWidth="74"/>
                        <Button Content="Cancel" Command="{Binding CancelSearchCommand}" Padding="10,2" Margin="0,0,3,0" MinWidth="74" Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Clear" Command="{Binding ClearResultsCommand}" Padding="10,2" MinWidth="66"/>
                    </StackPanel>
                </WrapPanel>
                <ProgressBar IsIndeterminate="True" Height="3" Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding StatusText}" Margin="0,2,0,0" Foreground="{StaticResource AppMutedTextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <Expander Grid.Row="2"
                      Margin="0,6,0,0"
                      IsExpanded="False"
                      Style="{StaticResource DisclosureExpanderStyle}">
                <Expander.Header>
                    <TextBlock Text="Filter" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,1"/>
                </Expander.Header>
                <StackPanel DataContext="{Binding FilterPanel}" Margin="0,2,0,0">
                    <Grid x:Name="FilterPrimaryRow">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,0,5,0">
                            <Border CornerRadius="6" Background="#FAFBFC" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=FilterQueryBox}" Value="True">
                                                <Setter Property="BorderBrush" Value="#8FA9C4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBox x:Name="FilterQueryBox" Background="Transparent" BorderThickness="0" Padding="9,2,7,2" VerticalContentAlignment="Center" Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ApplyFilterCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="Filter current tab or scope..." Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#9099A5" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FilterQueryBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,6,0" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActualWidth, ElementName=FilterPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <CheckBox Content="Regex" IsChecked="{Binding IsRegex}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <CheckBox Content="Case" IsChecked="{Binding CaseSensitive}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Apply" Command="{Binding ApplyFilterCommand}" Padding="10,2" Margin="0,0,3,0" MinWidth="90">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActualWidth, ElementName=FilterPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="3" Content="{Binding ClearFilterLabel}" Command="{Binding ClearFilterCommand}" Padding="10,2" MinWidth="120">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActualWidth, ElementName=FilterPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <WrapPanel Margin="0,3,0,0" VerticalAlignment="Center" ItemHeight="22">
                        <WrapPanel.Style>
                            <Style TargetType="WrapPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActualWidth, ElementName=FilterPrimaryRow, Converter={StaticResource LessThan}, ConverterParameter=980}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                        </WrapPanel.Style>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                            <CheckBox Content="Regex" IsChecked="{Binding IsRegex}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <CheckBox Content="Case" IsChecked="{Binding CaseSensitive}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Apply" Command="{Binding ApplyFilterCommand}" Padding="10,2" Margin="0,0,3,0" MinWidth="90"/>
                                <Button Content="{Binding ClearFilterLabel}" Command="{Binding ClearFilterCommand}" Padding="10,2" MinWidth="120"/>
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0" VerticalAlignment="Center" ItemHeight="22">
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock Text="Time:" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="From" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppMutedTextBrush}"/>
                            <TextBox Width="120" Padding="4,1" Text="{Binding FromTimestamp, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0" ToolTip="ISO-8601, yyyy-MM-dd HH:mm:ss, or HH:mm:ss.fff"/>
                            <TextBlock Text="To" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppMutedTextBrush}"/>
                            <TextBox Width="120" Padding="4,1" Text="{Binding ToTimestamp, UpdateSourceTrigger=PropertyChanged}" ToolTip="ISO-8601, yyyy-MM-dd HH:mm:ss, or HH:mm:ss.fff"/>
                        </StackPanel>
                    </WrapPanel>
                    <ProgressBar IsIndeterminate="True" Height="3" Visibility="{Binding IsApplying, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StatusText}" Margin="0,3,0,0" Foreground="{StaticResource AppMutedTextBrush}"/>
                    <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,5,0,0" Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FilterWarningViewModel}">
                                <Border Margin="0,0,0,5" Padding="7,5,7,5" CornerRadius="4" BorderBrush="#E5C07B" BorderThickness="1" Background="#FFF8E7">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Message}" Margin="0,1,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding FilePath}" Margin="0,1,0,0" FontSize="10" Foreground="{StaticResource AppMutedTextBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,8"
                    Padding="0,0,0,6"
                    BorderBrush="{StaticResource SearchWorkspaceResultsDividerBrush}"
                    BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="True" DataContext="{Binding SearchPanel}">
                    <TextBlock DockPanel.Dock="Left"
                               Margin="0,8,10,0"
                               Text="SEARCH RESULTS"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppMutedTextBrush}"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding ResultsHeaderText}"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <ListBox x:Name="SearchResultsList"
                     Grid.Row="2"
                     Margin="0,0,0,0"
                     DataContext="{Binding SearchPanel}"
                     ItemsSource="{Binding VisibleRows}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     SelectionMode="Extended"
                     PreviewKeyDown="SearchResultsList_PreviewKeyDown"
                     PreviewMouseRightButtonDown="SearchResultsList_PreviewMouseRightButtonDown"
                     MouseDoubleClick="SearchResultsList_MouseDoubleClick"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Selected Lines"
                                  InputGestureText="Ctrl+C"
                                  Click="CopySelectedSearchHits_Click"/>
                        <Separator/>
                        <MenuItem Header="Collapse Current Result Set"
                                  Click="CollapseCurrentSearchResults_Click"/>
                        <MenuItem Header="Collapse All Result Sets"
                                  Click="CollapseAllSearchResults_Click"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.Resources>
                    <DataTemplate DataType="{x:Type vm:SearchResultFileHeaderRowViewModel}">
                        <Border Background="{StaticResource SearchWorkspaceFileHeaderBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="4">
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding FileResult.IsExpanded, Mode=TwoWay}"
                                          Padding="0"
                                          HorizontalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="9"
                                               Foreground="#666"
                                               Style="{StaticResource DisclosureHeaderTriangleStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding FileResult.FileName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding FileResult.HitCount, StringFormat=' ({0})'}" Foreground="{StaticResource AppMutedTextBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </ToggleButton>
                        </Border>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SearchResultHitRowViewModel}">
                        <Grid Margin="16,2,4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Hit.LineNumber, StringFormat='L{0}: '}" Foreground="#355C7D"/>
                            <TextBlock Grid.Column="1" Text="{Binding Hit.LineText}" Style="{StaticResource LogText}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.Resources>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Focusable" Value="True"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
