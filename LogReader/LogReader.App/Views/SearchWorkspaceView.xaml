<UserControl x:Class="LogReader.App.Views.SearchWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LogReader.App.ViewModels"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="DisclosureHeaderTriangleStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="&#x25B6;"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True">
                    <Setter Property="Text" Value="&#x25BC;"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DisclosureExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Padding="0"
                                          HorizontalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="9"
                                               Foreground="#666"
                                               Style="{StaticResource DisclosureHeaderTriangleStyle}"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </ToggleButton>
                            <Grid x:Name="ExpandedContent" Margin="0,0,0,4" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1"
                                        Margin="0,1,0,1"
                                        Background="{StaticResource AppBorderBrush}"
                                        Opacity="0.7"
                                        SnapsToDevicePixels="True"/>
                                <ContentPresenter Grid.Column="3"/>
                            </Grid>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandedContent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,1,0,0">
        <Grid Margin="6,4,6,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0" Margin="0,0,0,6" VerticalAlignment="Center" ItemHeight="22" DataContext="{Binding SearchPanel}">
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Scope:" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold"/>
                    <RadioButton Content="Current file" IsChecked="{Binding AllFiles, Converter={StaticResource InvertBool}}" GroupName="WorkspaceScope" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Current scope" IsChecked="{Binding AllFiles}" GroupName="WorkspaceScope" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Width="1" Height="14" Margin="0,0,8,0" Background="{StaticResource AppBorderBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Source:" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold"/>
                    <RadioButton Content="Disk" IsChecked="{Binding IsDiskSnapshotMode}" GroupName="SearchDataMode" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Tail" IsChecked="{Binding IsTailMode}" GroupName="SearchDataMode" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Snapshot + Tail" IsChecked="{Binding IsSnapshotAndTailMode}" GroupName="SearchDataMode" VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>

            <Expander Grid.Row="1"
                      IsExpanded="True"
                      Style="{StaticResource DisclosureExpanderStyle}">
                <Expander.Header>
                    <TextBlock Text="Search" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,2"/>
                </Expander.Header>
                <StackPanel DataContext="{Binding SearchPanel}" Margin="0,4,0,6">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,0,5,0">
                            <Border CornerRadius="6" Background="#FAFBFC" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchBox}" Value="True">
                                                <Setter Property="BorderBrush" Value="#8FA9C4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Padding="9,2,7,2" VerticalContentAlignment="Center" Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ExecuteSearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="Search files..." Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#9099A5" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Content="Search" Command="{Binding ExecuteSearchCommand}" Padding="10,3" Margin="0,0,3,0" MinWidth="74"/>
                        <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelSearchCommand}" Padding="10,3" Margin="0,0,3,0" MinWidth="74" Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                        <Button Grid.Column="3" Content="Clear" Command="{Binding ClearResultsCommand}" Padding="10,3" MinWidth="66"/>
                    </Grid>
                    <WrapPanel Margin="0,0,0,2" VerticalAlignment="Center" ItemHeight="22">
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock Text="Order:" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold"/>
                            <RadioButton Content="Ascending" IsChecked="{Binding IsAscendingLineOrder}" GroupName="SearchLineOrder" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <RadioButton Content="Descending" IsChecked="{Binding IsDescendingLineOrder}" GroupName="SearchLineOrder" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Width="1" Height="14" Margin="0,0,8,0" Background="{StaticResource AppBorderBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                            <CheckBox Content="Regex" IsChecked="{Binding IsRegex}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <CheckBox Content="Case" IsChecked="{Binding CaseSensitive}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <CheckBox Content="Whole word" IsChecked="{Binding WholeWord}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                    <ProgressBar IsIndeterminate="True" Height="3" Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StatusText}" Margin="0,3,0,0" Foreground="{StaticResource AppMutedTextBrush}"/>
                </StackPanel>
            </Expander>

            <Expander Grid.Row="2"
                      IsExpanded="False"
                      Style="{StaticResource DisclosureExpanderStyle}">
                <Expander.Header>
                    <TextBlock Text="Filter" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" Margin="0,0,0,2"/>
                </Expander.Header>
                <StackPanel DataContext="{Binding FilterPanel}" Margin="0,4,0,6">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,0,5,0">
                            <Border CornerRadius="6" Background="#FAFBFC" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=FilterQueryBox}" Value="True">
                                                <Setter Property="BorderBrush" Value="#8FA9C4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBox x:Name="FilterQueryBox" Background="Transparent" BorderThickness="0" Padding="9,2,7,2" VerticalContentAlignment="Center" Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ApplyFilterCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="Filter current file or scope..." Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#9099A5" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FilterQueryBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Content="Apply Filter" Command="{Binding ApplyFilterCommand}" Padding="10,3" Margin="0,0,3,0" MinWidth="90"/>
                        <Button Grid.Column="2" Content="Clear" Command="{Binding ClearFilterCommand}" Padding="10,3" MinWidth="66"/>
                    </Grid>
                    <WrapPanel Margin="0,0,0,2" VerticalAlignment="Center" ItemHeight="22">
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock Text="Time:" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppTextBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="From" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppMutedTextBrush}"/>
                            <TextBox Width="120" Padding="4,1" Text="{Binding FromTimestamp, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0" ToolTip="ISO-8601, yyyy-MM-dd HH:mm:ss, or HH:mm:ss.fff"/>
                            <TextBlock Text="To" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{StaticResource AppMutedTextBrush}"/>
                            <TextBox Width="120" Padding="4,1" Text="{Binding ToTimestamp, UpdateSourceTrigger=PropertyChanged}" ToolTip="ISO-8601, yyyy-MM-dd HH:mm:ss, or HH:mm:ss.fff"/>
                        </StackPanel>
                        <Border Width="1" Height="14" Margin="0,0,8,0" Background="{StaticResource AppBorderBrush}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                            <CheckBox Content="Regex" IsChecked="{Binding IsRegex}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <CheckBox Content="Case" IsChecked="{Binding CaseSensitive}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <CheckBox Content="Whole word" IsChecked="{Binding WholeWord}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                    <ProgressBar IsIndeterminate="True" Height="3" Visibility="{Binding IsApplying, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StatusText}" Margin="0,3,0,0" Foreground="{StaticResource AppMutedTextBrush}"/>
                    <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,5,0,0" Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FilterWarningViewModel}">
                                <Border Margin="0,0,0,5" Padding="7,5,7,5" CornerRadius="4" BorderBrush="#E5C07B" BorderThickness="1" Background="#FFF8E7">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Message}" Margin="0,1,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding FilePath}" Margin="0,1,0,0" FontSize="10" Foreground="{StaticResource AppMutedTextBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <ListBox x:Name="SearchResultsList"
                     Grid.Row="3"
                     Margin="0,6,0,0"
                     DataContext="{Binding SearchPanel}"
                     ItemsSource="{Binding Results}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:FileSearchResultViewModel}">
                        <Expander IsExpanded="{Binding IsExpanded}" Margin="0,0,0,4">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding HitCount, StringFormat=' ({0})'}" Foreground="{StaticResource AppMutedTextBrush}"/>
                                </StackPanel>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding Hits}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     Margin="0,2,0,0"
                                     PreviewKeyDown="SearchHitsList_PreviewKeyDown"
                                     PreviewMouseRightButtonDown="SearchHitsList_PreviewMouseRightButtonDown"
                                     MouseDoubleClick="SearchHitsList_MouseDoubleClick"
                                     SelectionMode="Extended"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copy Selected Lines"
                                                  InputGestureText="Ctrl+C"
                                                  Click="CopySelectedSearchHits_Click"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding LineNumber, StringFormat='L{0}: '}" Foreground="#355C7D"/>
                                            <TextBlock Grid.Column="1" Text="{Binding LineText}" Style="{StaticResource LogText}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
