<Window x:Class="LogReader.App.Views.BulkOpenDashboardPathsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="820"
        Height="680"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="DialogTitleTextBlock"
                   FontSize="16"
                   FontWeight="Bold"/>

        <TextBlock x:Name="InstructionsTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,12"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   TextWrapping="Wrap"/>

        <TextBox x:Name="PathsTextBox"
                 Grid.Row="2"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="{DynamicResource LogFontFamilyResource}"
                 FontSize="12"
                 TextChanged="PathsTextBox_TextChanged"/>

        <TextBlock x:Name="PreviewStatusTextBlock"
                   Grid.Row="3"
                   Margin="0,12,0,6"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   TextWrapping="Wrap"/>

        <ListView x:Name="PreviewListView"
                  Grid.Row="4"
                  Margin="0,0,0,12">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Status" Width="90" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Path" Width="640" DisplayMemberBinding="{Binding FilePath}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="PreviewButton"
                    Content="Preview"
                    Width="90"
                    Padding="4,6"
                    Margin="0,0,8,0"
                    Click="Preview_Click"/>
            <Button x:Name="ConfirmButton"
                    Width="130"
                    Padding="4,6"
                    Margin="0,0,8,0"
                    Click="Confirm_Click"/>
            <Button Content="Cancel"
                    Width="80"
                    Padding="4,6"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
