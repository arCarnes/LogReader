<UserControl x:Class="LogReader.App.Views.LogViewportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LogReader.App.ViewModels"
             Background="Transparent">
    <Grid ContextMenuService.IsEnabled="{Binding IsCurrentScopeEmpty}">
        <Grid.ContextMenu>
            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                <MenuItem Header="Open Log File..."
                          Command="{Binding OpenFileCommand}"
                          InputGestureText="Ctrl+O"/>
                <MenuItem Header="Bulk Open Files..."
                          Command="{Binding BulkOpenAdHocFilesCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>
        <ContentControl x:Name="TabContentHost"
                        Content="{Binding SelectedTab}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:LogTabViewModel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Background="{StaticResource AppSurfaceBrush}"
                                    Height="28">
                            <TextBlock Text="Encoding:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <ComboBox Width="170"
                                      Margin="4,0,6,0"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding EncodingOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Encoding, Mode=TwoWay}"
                                      ToolTip="Change file encoding and reload"/>
                            <Button Content="Apply To All"
                                    Command="{Binding DataContext.ApplySelectedTabEncodingToAllCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource ToolBarButton}"
                                    Padding="5,2"
                                    Margin="0,0,6,0"
                                    ToolTip="Apply selected tab encoding to all open tabs"/>
                            <Separator Margin="8,2"/>
                            <Button Content="&#x2B06; Top"
                                    Command="{Binding JumpToTopCommand}"
                                    Style="{StaticResource ToolBarButton}"
                                    Padding="5,2"
                                    ToolTip="Jump to top"/>
                            <Button Content="&#x2B07; Bottom"
                                    Command="{Binding JumpToBottomCommand}"
                                    Style="{StaticResource ToolBarButton}"
                                    Padding="5,2"
                                    ToolTip="Jump to bottom"/>
                            <Separator Margin="8,2"/>
                            <CheckBox Content="Auto-scroll (all tabs)"
                                      IsChecked="{Binding DataContext.GlobalAutoScrollEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                      VerticalAlignment="Center"
                                      Margin="4,0"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ListBox Grid.Column="0"
                                     ItemsSource="{Binding VisibleLines}"
                                     SelectionMode="Extended"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="True"
                                     FontFamily="{DynamicResource LogFontFamilyResource}"
                                     FontSize="12"
                                     Foreground="{StaticResource AppTextBrush}"
                                     Background="{StaticResource AppBackgroundBrush}"
                                     BorderThickness="0"
                                     Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                     x:Name="LogListBox"
                                     PreviewMouseWheel="LogListBox_PreviewMouseWheel"
                                     PreviewKeyDown="LogListBox_PreviewKeyDown"
                                     SizeChanged="LogListBox_SizeChanged">
                                <ListBox.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                                 Opened="ViewportContextMenu_Opened">
                                        <MenuItem Header="Copy Selected Lines"
                                                  InputGestureText="Ctrl+C"
                                                  Click="CopySelectedLines_Click"
                                                  Tag="CopySelectedLines"/>
                                        <MenuItem Header="Open Log File..."
                                                  Command="{Binding OpenFileCommand}"
                                                  InputGestureText="Ctrl+O"
                                                  Tag="OpenLogFile"/>
                                        <MenuItem Header="Bulk Open Files..."
                                                  Command="{Binding BulkOpenAdHocFilesCommand}"
                                                  Tag="BulkOpenFiles"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="RowHighlight" Background="Transparent" Padding="0,0,4,0" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding LineNumber}"
                                                           Width="45"
                                                           Foreground="{StaticResource AppMutedTextBrush}"
                                                           TextAlignment="Right"
                                                           Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Text}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background"
                                                Value="{Binding HighlightColor, Converter={StaticResource HexColorToBrush}}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#B0D4FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                        <Style.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                        </Style.Resources>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            <ScrollBar Grid.Column="1"
                                       Orientation="Vertical"
                                       Minimum="0"
                                       Maximum="{Binding ScrollBarMaximum}"
                                       ViewportSize="{Binding ScrollBarViewportSize}"
                                       Value="{Binding ScrollBarValue, Mode=OneWay}"
                                       SmallChange="3"
                                       LargeChange="50"
                                       PreviewMouseLeftButtonDown="VerticalScrollBar_PreviewMouseLeftButtonDown"
                                       Scroll="VerticalScrollBar_Scroll"/>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{StaticResource AppSurfaceBrush}"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                Padding="4,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusText}" Margin="0,0,16,0"/>
                                <TextBlock Text="{Binding FilePath}"
                                           Foreground="{StaticResource AppMutedTextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <TextBlock Text="{Binding EmptyStateText}"
                   MaxWidth="520"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="16"
                   Foreground="{StaticResource AppMutedTextBrush}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCurrentScopeEmpty}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
