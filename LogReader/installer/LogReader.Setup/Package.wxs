<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
      Name="LogReader"
      Manufacturer="LogReader"
      Version="$(var.ProductVersion)"
      UpgradeCode="{FCACF4E0-7FBF-4D98-9E9E-BD854E7508EF}"
      Scope="perUser">
    <MajorUpgrade DowngradeErrorMessage="A newer version of LogReader is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="ProductIcon.ico" SourceFile="..\..\LogReader.App\Assets\favicon.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon.ico" />
    <Property Id="STORAGEROOTDIR">
      <RegistrySearch
          Root="HKCU"
          Key="Software\LogReader"
          Name="StorageRoot"
          Type="raw" />
    </Property>

    <ui:WixUI
        Id="WixUI_InstallDir"
        InstallDirectory="STORAGEROOTDIR" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="PROGRAMSDIR" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="LogReader" />
      </Directory>
      <Directory Id="STORAGEROOTDIR" Name="LogReader" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="LogReader" />
    </StandardDirectory>

    <ComponentGroup Id="InstallerMetadataComponents">
      <Component Directory="INSTALLFOLDER" Id="InstalledStateComponent" Guid="{8F7B52B4-14DB-4CB2-8A4E-124EA45A18E5}">
        <RegistryValue Root="HKCU" Key="Software\LogReader" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
        <RegistryValue Root="HKCU" Key="Software\LogReader" Name="StorageRoot" Type="string" Value="[STORAGEROOTDIR]" />
        <RegistryValue Root="HKCU" Key="Software\LogReader" Name="InstallRoot" Type="string" Value="[INSTALLFOLDER]" />
      </Component>

      <Component Directory="ProgramMenuDir" Id="ProgramMenuShortcutComponent" Guid="{5E83671C-1A74-4D57-B920-3E8C2BF8E297}">
        <Shortcut
            Id="ApplicationShortcut"
            Name="LogReader"
            Description="LogReader"
            Target="[INSTALLFOLDER]$(var.ExecutableName)"
            WorkingDirectory="INSTALLFOLDER"
            Icon="ProductIcon.ico"
            IconIndex="0"
            Advertise="no" />
        <RemoveFolder Id="RemoveProgramMenuDir" Directory="ProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\LogReader" Name="ProgramMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <SetProperty
        Id="WriteRuntimeConfiguration"
        Value="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command &quot;&amp; { param([string]$RuntimeConfigPath, [string]$StorageRoot) $payload = @{ storageRoot = $StorageRoot } | ConvertTo-Json -Compress; Set-Content -LiteralPath $RuntimeConfigPath -Value $payload -Encoding ASCII }&quot; &quot;[INSTALLFOLDER]LogReader.runtime.json&quot; &quot;[STORAGEROOTDIR]&quot;"
        Sequence="execute"
        Before="WriteRuntimeConfiguration"
        Condition="NOT REMOVE" />

    <CustomAction
        Id="WriteRuntimeConfiguration"
        BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
        DllEntry="WixQuietExec"
        Execute="deferred"
        Return="check"
        Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="WriteRuntimeConfiguration" After="InstallFiles" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <Feature Id="Complete" Title="LogReader" Level="1">
      <ComponentGroupRef Id="HarvestedApplicationFiles" />
      <ComponentGroupRef Id="InstallerMetadataComponents" />
    </Feature>
  </Package>
</Wix>
